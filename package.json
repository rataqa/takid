{
  "name": "@rataqa/takid",
  "version": "1.0.2",
  "description": "JSON Schema validation using OpenAPI schemas and AJV",
  "type": "commonjs",
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf ./dist",
    "build:ts": "tsc --project tsconfig.build.json",
    "build": "npm-run-all clean build:ts",
    "test": "node -r ts-node/register --test src/__tests__/*.test.ts",
    "test:coverage": "node -r ts-node/register --experimental-test-coverage --test src/__tests__/*.test.ts"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "dotenv": "^17.3.1",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "homepage": "https://github.com/rataqa/takid#readme",
  "bugs": {
    "url": "https://github.com/rataqa/takid/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rataqa/takid.git"
  },
  "license": "MIT",
  "author": "Rataqa Team",
  "keywords": [
    "ajv",
    "jsonschema",
    "openapi",
    "validator",
    "typescript"
  ]
}
